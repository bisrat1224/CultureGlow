NEXT_PUBLIC_WHATSAPP_NUMBER=251900000000
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Server-only — never exposed to browser
RESEND_API_KEY=
CONTACT_FORM_RECIPIENT_EMAIL=
CATERING_FORM_RECIPIENT_EMAIL=

# === ADMIN DASHBOARD (Post-launch) ===
# Database
DATABASE_URL="postgresql://user:password@host:5432/cultureglow24"

# Admin Session
ADMIN_SESSION_SECRET="generate-a-32-character-random-string-here"

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=
