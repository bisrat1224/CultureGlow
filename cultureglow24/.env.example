# ============================================
# CultureGlow24 — Environment Configuration
# ============================================

# --- DATABASE (Required) ---
DATABASE_URL=postgresql://user:password@host:5432/cultureglow24?sslmode=require

# --- PAYLOAD CMS (Required) ---
PAYLOAD_SECRET=generate-a-32-character-random-string-here

# --- PUBLIC URLS ---
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
NEXT_PUBLIC_WHATSAPP_NUMBER=251900000000
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# --- EMAIL (Optional) ---
RESEND_API_KEY=
CONTACT_FORM_RECIPIENT_EMAIL=hello@cultureglow24.com
CATERING_FORM_RECIPIENT_EMAIL=hello@cultureglow24.com

# --- SMTP (Optional — for password reset) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# --- CLOUDINARY (Optional — media storage) ---
